<!DOCTYPE html>
<html>
<head>

<title>Season Calendar App</title>

<style>


body{

font-family:Arial;
text-align:center;
padding:30px;
color:white;
transition:1s;
background-size:cover;
background-position:center;
min-height:100vh;

}



/* 🌸 Spring */

.spring{

background:
linear-gradient(
rgba(255,120,180,.35),
rgba(100,200,100,.35)
),
url("https://images.unsplash.com/photo-1490750967868-88aa4486c946");

background-size:cover;

}




/* ☀️ Summer */

.summer{

background:
linear-gradient(
rgba(255,200,0,.35),
rgba(255,120,0,.35)
),
url("https://images.unsplash.com/photo-1507525428034-b723cf961d3e");

background-size:cover;

}




/* 🍂 Autumn */

.autumn{

background:
linear-gradient(
rgba(220,100,0,.45),
rgba(100,40,80,.45)
),
url("https://images.unsplash.com/photo-1507371341162-763b5e419408");

background-size:cover;

}





/* ❄️ Winter */

.winter{

background:
linear-gradient(
rgba(0,120,220,.35),
rgba(200,240,255,.35)
),
url("https://images.unsplash.com/photo-1517299321609-52687d1bc55a");

background-size:cover;

}





.calendar{

width:420px;

background:rgba(0,0,0,.75);

margin:auto;

padding:20px;

border-radius:25px;

box-shadow:0 0 25px black;

}




.header{

display:flex;

justify-content:space-between;

align-items:center;

}




button{

background:#00e676;

border:none;

padding:10px 15px;

border-radius:10px;

font-size:18px;

cursor:pointer;

}




.days{

display:grid;

grid-template-columns:repeat(7,1fr);

margin-top:20px;

}





.day-name{

color:#00e676;

font-weight:bold;

}




.date{

background:#333;

padding:15px;

margin:3px;

border-radius:8px;

cursor:pointer;

transition:.3s;

}





.date:hover{

background:#00e676;

color:black;

transform:scale(1.1);

}




.today{

background:#00e676;

color:black;

}





#season{

font-size:30px;

font-weight:bold;

animation:fade 1s;

}





@keyframes fade{

from{

opacity:0;

}

to{

opacity:1;

}

}





#clock{

font-size:20px;

}



</style>

</head>


<body>



<div class="calendar">


<h1>📅 Season Calendar</h1>



<div id="season"></div>



<h3 id="clock"></h3>



<div class="header">


<button onclick="prevMonth()">⬅</button>


<h2 id="month"></h2>


<button onclick="nextMonth()">➡</button>


</div>




<div class="days">


<div class="day-name">Sun</div>

<div class="day-name">Mon</div>

<div class="day-name">Tue</div>

<div class="day-name">Wed</div>

<div class="day-name">Thu</div>

<div class="day-name">Fri</div>

<div class="day-name">Sat</div>


</div>




<div class="days" id="dates"></div>



</div>





<script>



let date=new Date();



function showCalendar(){



let year=date.getFullYear();

let month=date.getMonth();



let months=[

"January","February","March",

"April","May","June",

"July","August","September",

"October","November","December"

];




document.getElementById("month").innerHTML=

months[month]+" "+year;





let season="";



document.body.className="";




if(month>=2 && month<=4){


document.body.classList.add("spring");

season="🌸 Spring Season";


}




else if(month>=5 && month<=7){


document.body.classList.add("summer");

season="☀️ Summer Season";


}




else if(month>=8 && month<=10){


document.body.classList.add("autumn");

season="🍂 Autumn Season";


}





else{


document.body.classList.add("winter");

season="❄️ Winter Season";


}





document.getElementById("season").innerHTML=season;







let firstDay=

new Date(year,month,1).getDay();




let lastDate=

new Date(year,month+1,0).getDate();




let box=document.getElementById("dates");


box.innerHTML="";





for(let i=0;i<firstDay;i++){


box.innerHTML+="<div></div>";


}






for(let i=1;i<=lastDate;i++){



let today=new Date();




let active=

i==today.getDate()

&& month==today.getMonth()

&& year==today.getFullYear();






box.innerHTML+=`


<div class="date ${active?'today':''}"

onclick="selectDate(${i})">


${i}


</div>


`;



}



}






function nextMonth(){


date.setMonth(date.getMonth()+1);


showCalendar();


}






function prevMonth(){


date.setMonth(date.getMonth()-1);


showCalendar();


}






function selectDate(day){


alert("📅 Selected Date : "+day);


}








function clock(){


let now=new Date();



document.getElementById("clock").innerHTML=

"⏰ "+now.toLocaleTimeString();



}



setInterval(clock,1000);



clock();



showCalendar();



</script>


</body>

</html>
